# ---------------------------------------------------------------------------
# Binance Trend Bot — example environment file.
# Copy to `.env` and override only what you need. All values have defaults.
# API keys are NOT required: this bot consumes public market data only.
# ---------------------------------------------------------------------------

# --- Candle / data ---
INTERVAL=1m
WINDOW_SIZE=30

# --- Detection thresholds ---
R_SQUARED_MIN=0.75
EMA_FAST=9
EMA_SLOW=21
ROC_MIN=0.008
VOLUME_MULT=1.2

# --- Detection condition toggles (turn individual checks on/off) ---
USE_R_SQUARED=true
USE_EMA=true
USE_ROC=true
USE_VOLUME=true

# --- Universe liquidity filter ---
MIN_QUOTE_VOLUME_24H=500000

# --- Alerting ---
COOLDOWN_MINUTES=15
# Leave the two below empty to log to console only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Connectivity / limits (sane defaults; rarely changed) ---
REST_BASE_URL=https://fapi.binance.com
WS_BASE_URL=wss://fstream.binance.com
REST_WEIGHT_LIMIT=2400
REST_WEIGHT_THROTTLE_RATIO=0.8
# WARMUP_KLINES must be > WINDOW_SIZE (the latest REST kline is the still-forming
# candle and is dropped, so we need strictly more than one full window).
WARMUP_KLINES=50
MAX_STREAMS_PER_CONNECTION=200

# --- Data source ---
# ws     : WebSocket push only
# rest   : REST polling only (use when WS market data can't reach your network)
# hybrid : WS first, auto-fallback to REST polling if no WS frames arrive (default)
DATA_SOURCE=hybrid
# hybrid: activate REST polling after this many seconds with no WS frames
WS_STALE_SECONDS=30

# --- Logging ---
LOG_LEVEL=INFO
